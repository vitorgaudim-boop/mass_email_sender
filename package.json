{
  "name": "envio-de-cupons",
  "version": "1.0.0",
  "description": "Desktop bulk email sender for SendGrid campaigns.",
  "type": "module",
  "main": "main/main.js",
  "author": "Codex",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "package": "npm run build",
    "test": "vitest run",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/source-serif-4": "^5.2.5",
    "@fontsource/space-grotesk": "^5.2.6",
    "@monaco-editor/react": "^4.7.0",
    "dompurify": "^3.2.6",
    "dotenv": "^16.6.1",
    "electron-log": "^5.4.3",
    "eml-format": "^0.6.1",
    "html-to-text": "^9.0.5",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "validator": "^13.15.15",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^26.1.0",
    "vite": "^7.1.3",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.codex.enviodecupons",
    "productName": "Envio de Cupons",
    "files": [
      "main/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist/release"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
